# Skopiuj do .env i uzupełnij (plik .env jest gitignorowany).

# --- Baza ---
# VPS (natywny Postgres przez host.docker.internal, bez SSL):
# CONNECTION_STRING=Host=host.docker.internal;Port=5432;Database=czytnik;Username=czytnik_app;Password=HASLO_APP;Ssl Mode=Disable;
# Neon / zewnętrzny Postgres:
CONNECTION_STRING=Host=twoj-host.neon.tech;Database=czytnik;Username=user;Password=haslo;Ssl Mode=Require;Trust Server Certificate=true;

# --- Stripe (tryb testowy) ---
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# DEV: docker compose run --rm --no-deps stripe-cli listen --print-secret
# PROD: Dashboard (tryb Test) -> Webhooks -> endpoint na /Checkout/Webhook
STRIPE_WEBHOOK_SECRET=

# --- Poczta ---
# DEV (Mailpit w compose, profil dev):
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USESSL=false
EMAIL_FROM=sklep@czytnik.local

# PROD (Gmail SMTP; hasło aplikacji wymaga 2FA, FROM musi = USERNAME):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=twoj.adres@gmail.com
# EMAIL_PASSWORD=haslo-aplikacji-16-znakow
# EMAIL_USESSL=true
# EMAIL_FROM=twoj.adres@gmail.com
